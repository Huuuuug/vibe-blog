# Required for real Notion content fetching
NOTION_TOKEN=
NOTION_DATA_SOURCE_ID=

# Optional public site URL used for metadata and sitemap generation
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional secret for POST /api/revalidate via x-revalidate-secret header
REVALIDATE_SECRET=

# Optional Notion property name overrides
NOTION_TITLE_PROPERTY=Title
NOTION_SLUG_PROPERTY=Slug
NOTION_SUMMARY_PROPERTY=Summary
NOTION_PUBLISHED_AT_PROPERTY=PublishedAt
NOTION_TAGS_PROPERTY=Tags
NOTION_CATEGORY_PROPERTY=Category
NOTION_COVER_PROPERTY=Cover
NOTION_FEATURED_PROPERTY=Featured
NOTION_STATUS_PROPERTY=Status
NOTION_PUBLISHED_VALUE=Published
